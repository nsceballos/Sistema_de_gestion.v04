
# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID de la hoja de cálculo de Google Sheets (aparece en la URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
GOOGLE_SPREADSHEET_ID=TU_SPREADSHEET_ID_AQUI

# Credenciales de la cuenta de servicio de Google Cloud (JSON completo en una sola línea)
# Ver instrucciones de configuración en SETUP_GOOGLE_SHEETS.md
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"tu-proyecto","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"nombre@tu-proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ── JWT ────────────────────────────────────────────────────────────────────────
# Secreto para firmar los tokens JWT (usar una cadena larga y aleatoria en producción)
JWT_SECRET=cambiar_este_secreto_por_uno_seguro_en_produccion

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173